{
	"permissions": {
		"ask": [
			"Bash(git commit*)",
			"Bash(pnpm db:migrate*)",
			"Bash(pnpm db:seed*)"
		]
	},
	"hooks": {
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "pnpm check",
						"timeout": 30,
						"statusMessage": "Running Biome check..."
					}
				]
			}
		]
	}
}
