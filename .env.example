# Copy this file to .env.local, then review the values below.

# Local SQLite database path. Leave this as-is unless you want a different file.
DATABASE_FILE=db/local.db

# Anthropic API key. Required for AI tutor and question-generation workflows.
ANTHROPIC_API_KEY=sk-ant-...

# Model used by agent-driven workflows. Leave the default unless you need another one.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Default number of question-generation agents to run in parallel.
QUESTION_GEN_CONCURRENCY=5
