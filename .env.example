# Copy this file to .env.local and fill in the values

# Path to the SQLite database file
DATABASE_URL=file:./db/local.db

# Anthropic API key — required by the question-generation agent.
ANTHROPIC_API_KEY=sk-ant-...

# Model the generation agent uses (overridable per call).
ANTHROPIC_MODEL=claude-sonnet-4-6

# How many generation agents run in parallel per batch (default).
QUESTION_GEN_CONCURRENCY=5
